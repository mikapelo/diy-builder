# URL publique de l'API backend (accessible depuis le navigateur)
NEXT_PUBLIC_API_URL=http://localhost:4000

# Analytics Plausible — privacy-first, CNIL-exempt (pas de bannière de consentement)
# Obtenir sur https://plausible.io → Settings → Domain
# Laisser vide en dev pour désactiver le tracking
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=diy-builder.fr
