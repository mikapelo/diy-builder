{
  "name": "diy-builder-frontend",
  "version": "2.0.0",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "clean": "rm -rf .next",
    "clean:all": "rm -rf .next node_modules package-lock.json",
    "test": "vitest run",
    "test:ui": "vitest --ui",
    "lint": "next lint",
    "qa:quick": "vitest run",
    "qa:watch": "vitest",
    "qa:full": "vitest run && npm run build",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "prepare": "husky"
  },
  "dependencies": {
    "@react-three/drei": "^9.120.4",
    "@react-three/fiber": "^8.17.5",
    "@rolldown/binding-linux-arm64-gnu": "^1.0.0-rc.16",
    "jspdf": "^4.2.0",
    "next": "14.0.4",
    "next-pwa": "^5.6.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "three": "^0.160.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitest/ui": "^4.1.0",
    "autoprefixer": "10.4.16",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.4",
    "husky": "^9.1.7",
    "jsdom": "^29.0.1",
    "postcss": "8.4.32",
    "tailwindcss": "3.4.0",
