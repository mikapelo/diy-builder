PORT=4000
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

DB_HOST=localhost
DB_PORT=5432
DB_NAME=diy_builder
DB_USER=postgres
DB_PASSWORD=votre_mot_de_passe

# ── Configuration scrapers ─────────────────────────────────────
# Timeout réseau par requête (ms)
SCRAPER_TIMEOUT_MS=15000
# Nombre de tentatives avant abandon
SCRAPER_MAX_RETRY=3
# Délai de politesse entre requêtes (ms)
SCRAPER_DELAY_MS=2000

# ── Mode Playwright ───────────────────────────────────────────
# Mettre true pour utiliser Playwright headless à la place d'axios.
# Playwright passe le challenge Cloudflare JS → résultats sur LM/Casto/BD.
# Requiert : npm install playwright && npx playwright install chromium
# Plus lent (~3-6s/page), mais seule option contre les SPAs/Cloudflare.
USE_PLAYWRIGHT=false

# ── ScrapingBee — bypass DataDome pour Leroy Merlin et Brico Dépôt ────
# Créer un compte gratuit sur scrapingbee.com (1 000 crédits/mois offerts).
# Une fois la clé obtenue dans le dashboard, la coller ici.
# Routing automatique : LM + BD → ScrapingBee, Castorama → Playwright.
# Coût : ~360 crédits/run complet (5 crédits/page × 72 pages).
SCRAPINGBEE_API_KEY=

# ── Clé optionnelle pour protéger POST /api/catalog/update ────
# Si définie, ajouter le header : Authorization: Bearer <valeur>
# CATALOG_SECRET=votre_cle_secrete
