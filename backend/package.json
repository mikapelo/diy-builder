{
  "name": "diy-builder-backend",
  "version": "3.0.0",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --runInBand --forceExit",
    "test:watch": "jest --watch",
    "db:init": "psql $DATABASE_URL -f ../database/schema.sql",
    "db:migrate": "psql $DATABASE_URL -f ../database/migration_scraper.sql",
    "catalog:update": "node scripts/updateCatalog.js",
    "prices:update": "USE_PLAYWRIGHT=true node scripts/updateMaterialPrices.js",
    "prices:dry-run": "USE_PLAYWRIGHT=true node scripts/updateMaterialPrices.js --dry-run",
    "prices:from-file": "node scripts/updateMaterialPrices.js --from-file"
  },
  "dependencies": {
    "axios": "^1.6.5",
    "cheerio": "^1.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "playwright": "^1.59.1",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "nodemon": "^3.0.2",
    "supertest": "^6.3.4"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/tests/**/*.test.js"
    ]
  }
}
